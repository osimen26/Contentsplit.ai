# ContentSplit.ai Environment Configuration
# Copy this file to .env.local for local development or .env.production for production

# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# Authentication
VITE_AUTH_TOKEN_KEY=auth_token
VITE_AUTH_REFRESH_TOKEN_KEY=auth_refresh_token

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_LOGGING=false

# Third-Party Services (if applicable)
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=
# VITE_STRIPE_PUBLIC_KEY=

# Application Settings
VITE_APP_NAME=ContentSplit.ai
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Build Configuration
VITE_BUILD_TIMESTAMP=

# Note: All environment variables prefixed with VITE_ are exposed to the client-side code.
# Never expose sensitive secrets like API keys, database credentials, or private keys.