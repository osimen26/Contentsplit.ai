# ContentSplit.ai Server Environment Configuration
# Copy this file to .env for local development.
# NEVER commit .env files - they are in .gitignore

# Server Configuration
PORT=3001
NODE_ENV=development

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Flutterwave (Test Mode - DO NOT commit real keys)
# Get these from: https://dashboard.flutterwave.com/settings/apis
# Public key (safe for frontend)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxx-X
# Secret key (SERVER-SIDE ONLY - NEVER expose to frontend)
# Format: FLWSECK-TEST-xxxxxxxxxxxxxxxxxxxxx-X (with dashes)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx-X
# Webhook secret (for verifying webhook signatures)
# Get from: https://dashboard.flutterwave.com/settings/webhooks
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret_here

# App URL for redirects
APP_URL=http://localhost:5173

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# IMPORTANT SECURITY NOTES:
# 1. NEVER commit .env files - they are in .gitignore
# 2. FLUTTERWAVE_SECRET_KEY is for SERVER-SIDE only
# 3. Use FLUTTERWAVE_PUBLIC_KEY (VITE_ version) for frontend
# 4. Test keys start with TEST-, live keys start with FLWSECK-LIVE-
# 5. The key format is: FLWSECK-TEST-xxxxxxxxxxxxxxxxxxxxx-X (with dashes)
