# ContentSplit.ai - Server Environment Variables
# Copy this to server/.env and fill in your values

# Server port
PORT=3001

# DeepSeek API Key (required for AI content generation)
# Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase Configuration (optional - uses mock database if not set)
# Get from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# For database write access (admin operations)
# Use service_role key cautiously - it bypasses RLS
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here