# Production Environment Variables
# IMPORTANT: Set these in Vercel Dashboard > Project Settings > Environment Variables

# Required - DeepSeek API (get from https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-key-here

# Required - Supabase (get from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Optional - Stripe (get from Stripe Dashboard)
# STRIPE_SECRET_KEY=
# STRIPE_PRO_PRICE_ID=
# STRIPE_AGENCY_PRICE_ID=

# Optional - Flutterwave
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=

# Optional - Google OAuth (get from Google Cloud Console)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Server config (defaults work)
PORT=3001