# Production Environment Variables
# IMPORTANT: Set these in Vercel Dashboard > Project Settings > Environment Variables
# DO NOT commit actual keys to this file

PORT=3001

# Required - Set in Vercel Dashboard
DEEPSEEK_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# Frontend URL (for password reset links)
APP_URL=https://contentsplit.ai

# Optional - Stripe
# STRIPE_SECRET_KEY=

# Optional - Flutterwave  
# FLUTTERWAVE_PUBLIC_KEY=

# Optional - Google OAuth
# GOOGLE_CLIENT_ID=